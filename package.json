{
  "name": "haru",
  "type": "module",
  "scripts": {
    "dev" : "dev:css & bun run dev:wrangler",
    "dev:css": "bunx @tailwindcss/cli -i ./public/style-i.css -o ./public/style-o.css --watch",
    "dev:wrangler": "wrangler dev",
    "build:css" : "bunx @tailwindcss/cli -i ./public/style-i.css -o ./public/style-o.css",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "@photonjs/hono": "^0.1.12",
    "@tailwindcss/cli": "^4.3.0",
    "@tidbcloud/serverless": "^0.3.0",
    "arctic": "^3.7.0",
    "hono": "^4.12.18",
    "tailwindcss": "^4.3.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260526.1",
    "wrangler": "^4.4.0"
  }
}